{
  "name": "@samarth208p/0mcp",
  "version": "2.0.4",
  "description": "Persistent memory layer for AI coding agents — 0G + ENS + Brain iNFT",
  "type": "module",
  "main": "./build/src/index.js",
  "bin": {
    "0mcp": "./build/src/cli.js"
  },
  "files": [
    "build",
    "contracts",
    "README.md",
    "0mcp.png"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "setup": "node --loader ts-node/esm src/cli.ts init",
    "cli": "node --loader ts-node/esm src/cli.ts",
    "cli:debug": "cross-env DEBUG_CLI=true node --loader ts-node/esm src/cli.ts",
    "dev": "node --loader ts-node/esm src/index.ts",
    "start": "node build/src/index.js",
    "demo": "node --loader ts-node/esm scripts/demo.ts",
    "demo:debug": "cross-env DEBUG_CONTEXT=true node --loader ts-node/esm scripts/demo.ts",
    "health:0g": "node --loader ts-node/esm scripts/check-0g.ts",
    "mint": "node --loader ts-node/esm scripts/mint-demo.ts",
    "register-agent": "node --loader ts-node/esm scripts/register-agent.ts",
    "issue-rental": "node --loader ts-node/esm scripts/issue-rental.ts",
    "verify-access": "node --loader ts-node/esm scripts/verify-access.ts",
    "lint": "eslint src scripts --ext .ts",
    "format": "prettier --write \"src/**/*.ts\" \"scripts/**/*.ts\""
  },
  "dependencies": {
    "@0gfoundation/0g-ts-sdk": "^1.2.6",
    "@account-abstraction/contracts": "^0.8.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@openzeppelin/contracts": "^5.6.1",
    "@uniswap/sdk-core": "^7.13.0",
    "@uniswap/v4-sdk": "^2.0.0",
    "ethers": "^6.13.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "cross-env": "^7.0.3",
    "eslint": "^9.0.0",
    "prettier": "^3.3.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.2"
  }
}
