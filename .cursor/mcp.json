{
  "mcpServers": {
    "0mcp": {
      "command": "node",
      "args": ["build/src/index.js"],
      "env": {
        "MOCK_STORAGE": "false",
        "ZG_RPC_URL": "${ZG_RPC_URL}",
        "ZG_KV_NODE": "${ZG_KV_NODE}",
        "ZG_KV_FALLBACK_NODE": "${ZG_KV_FALLBACK_NODE}",
        "ZG_INDEXER_RPC": "${ZG_INDEXER_RPC}",
        "ZG_PRIVATE_KEY": "${ZG_PRIVATE_KEY}",
        "INFT_CONTRACT_ADDRESS": "${INFT_CONTRACT_ADDRESS}",
        "ENS_PRIVATE_KEY": "${ENS_PRIVATE_KEY}",
        "SEPOLIA_RPC_URL": "${SEPOLIA_RPC_URL}",
        "KEEPER_API_KEY": "${KEEPER_API_KEY}"
      }
    }
  }
}
