# =============================================================================
# 0MCP — Environment Variables
# Copy this to .env and fill in your values.
# BETTER: run `0mcp init` — it generates this file for you automatically.
# NEVER commit .env to git.
# =============================================================================

# ── 0G Network (Galileo Testnet) ──────────────────────────────────────────────
# RPC endpoint for 0G Galileo testnet EVM
# Docs: https://docs.0g.ai/build-with-0g/networks
ZG_RPC_URL=https://evmrpc-testnet.0g.ai
ZG_CHAIN_ID=16602

# 0G storage indexer — Turbo is the active Galileo storage network
# Docs: https://docs.0g.ai/build-with-0g/storage-sdk
ZG_INDEXER_RPC=https://indexer-storage-testnet-turbo.0g.ai

# Optional fallback indexer endpoint
ZG_INDEXER_FALLBACK_RPC=https://indexer-storage-testnet-standard.0g.ai

# On-chain registry that maps project IDs → 0G storage root hashes
MEMORY_REGISTRY_ADDRESS=0x1aa3A642Ee0fE818471B0B3e75157cbbaA8C75CD

# Your testnet wallet private key (0x-prefixed)
# Get testnet OG tokens free: https://faucet.0g.ai
ZG_PRIVATE_KEY=0x_your_private_key_here

# ── Brain iNFT Contract ────────────────────────────────────────────────────────
# SimpleINFT.sol deployed on 0G Galileo (ERC-7857)
# Pre-deployed address — no need to deploy yourself
INFT_CONTRACT_ADDRESS=0xd07059e54017BbF424223cb089ffBC5e2558cF56

# Your wallet address (for minting to yourself)
MY_WALLET_ADDRESS=0x_your_wallet_address_here

# ── ENS (Sepolia Testnet) ─────────────────────────────────────────────────────
# Private key for ENS operations. Can be same as ZG_PRIVATE_KEY.
# Get Sepolia ETH: https://sepoliafaucet.com
ENS_PRIVATE_KEY=0x_your_private_key_here

# Parent ENS name under which brain subnames are created
ENS_PARENT_NAME=0mcp.eth

# Sepolia RPC (for ENS interactions)
SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com

# Official ENS Sepolia contract deployments (do not change)
ENS_REGISTRY_ADDRESS=0x00000000000C2E074eC69A0dFb2997BA6C7d2e1e
ENS_RESOLVER_ADDRESS=0xE99638b40E4Fff0129D56f03b55b6bbC4BBE49b5
ENS_NAME_WRAPPER_ADDRESS=0x0635513f179D50A207757E05759CbD106d7dFcE8
ENS_REVERSE_REGISTRAR_ADDRESS=0x4F382928805ba0e23B30cFB75fC9E848e82DFD47

# Default duration for rental subnames
RENTAL_DURATION_DAYS=30

# ── Brain ENS Identity ─────────────────────────────────────────────────────────
# Set BRAIN_ENS_LABEL to your desired brain name (e.g. "sampy").
# The server will auto-register sampy.0mcp.eth the first time it starts.
# Leave blank if you don't want ENS registration yet.
BRAIN_ENS_LABEL=

# Full ENS name (auto-filled by the server after registration)
BRAIN_ENS_NAME=

# "true" once registration/detection completes. Reset to "" to force re-probe.
BRAIN_ENS_REGISTERED=

# "own" = you own this brain | "loaded" = imported from another wallet
BRAIN_ENS_MODE=

# Rental / access config
RENTER_ADDRESS=
RENTER_SUBNAME=

# ── KeeperHub ─────────────────────────────────────────────────────────────────
# MCP endpoint: https://app.keeperhub.com/mcp
# Generate your API key: https://app.keeperhub.com → Settings → API Keys
KEEPER_API_KEY=kh_your_api_key_here

# ── ZeroG Paymaster (Gas Sponsorship for ENS) ────────────────────────────────
# Sponsors Sepolia gas for ENS operations so users don't need Sepolia ETH.
PAYMASTER_ADDRESS=0xb1Ab695dbcbA334A60712234d46264A617AD6d7f
PAYMASTER_RELAY_URL=https://relay.0mcp.eth.limo
PAYMASTER_BUNDLER_URL=https://api.pimlico.io/v2/sepolia/rpc?apikey=public
RELAY_SIGNER_ADDRESS=0x_your_wallet_address_here

# ── Developer Options ─────────────────────────────────────────────────────────
# Print keyword scores during context retrieval (debug/demo)
DEBUG_CONTEXT=false

# Human-readable description for your brain
AGENT_DESCRIPTION=0MCP Brain agent
