# =============================================================================
# 0MCP — Environment Variables
# Copy this to .env and fill in your values.
# NEVER commit .env to git.
# =============================================================================

# ── 0G Network (Galileo Testnet) ──────────────────────────────────────────────
# RPC endpoint for 0G Galileo testnet EVM
# Docs: https://docs.0g.ai/build-with-0g/networks
ZG_RPC_URL=https://evmrpc-testnet.0g.ai
ZG_CHAIN_ID=16602

# Legacy public KV node (older docs/examples). Not used by the current live backend.
ZG_KV_NODE=http://3.101.147.150:6789

# Legacy fallback KV node
ZG_KV_FALLBACK_NODE=http://3.101.147.150:6790

# 0G storage indexer — Turbo is the active Galileo storage network
# Docs: https://docs.0g.ai/build-with-0g/storage-sdk
ZG_INDEXER_RPC=https://indexer-storage-testnet-turbo.0g.ai

# Optional fallback indexer endpoint (standard is currently under maintenance)
ZG_INDEXER_FALLBACK_RPC=https://indexer-storage-testnet-standard.0g.ai

# On-chain registry that stores the latest 0G storage root per project
MEMORY_REGISTRY_ADDRESS=0x_your_memory_registry_address_here

# Your testnet wallet private key (0x-prefixed)
# Get testnet OG tokens free at: https://faucet.0g.ai
ZG_PRIVATE_KEY=0x_your_private_key_here

# ── Brain iNFT Contract ────────────────────────────────────────────────────────
# Address of SimpleINFT.sol deployed on 0G Galileo testnet (chain ID 16602)
# Deploy with Foundry: forge create --rpc-url $ZG_RPC_URL ...
# Leave blank until Phase 4 deployment
INFT_CONTRACT_ADDRESS=

# Your wallet address (for minting iNFTs to yourself)
MY_WALLET_ADDRESS=0x_your_wallet_address_here

# ── ENS (Sepolia Testnet) ─────────────────────────────────────────────────────
# Private key for the wallet that owns 0mcp.eth on Sepolia
# Can be same as ZG_PRIVATE_KEY if same wallet
# Sepolia ENS: https://app.ens.domains (switch to Sepolia in wallet)
# Get Sepolia ETH: https://sepoliafaucet.com
ENS_PRIVATE_KEY=0x_your_private_key_here

# Parent ENS name under which 0MCP agent names are created
ENS_PARENT_NAME=0mcp.eth

# Sepolia RPC (for ENS interactions)
# Free Sepolia RPC: https://rpc.sepolia.org  OR  https://1rpc.io/sepolia
SEPOLIA_RPC_URL=https://rpc.sepolia.org

# Official ENS Sepolia contract deployments
ENS_REGISTRY_ADDRESS=0x00000000000C2E074eC69A0dFb2997BA6C7d2e1e
ENS_RESOLVER_ADDRESS=0xE99638b40E4Fff0129D56f03b55b6bbC4BBE49b5
ENS_NAME_WRAPPER_ADDRESS=0x0635513f179D50A207757E05759CbD106d7dFcE8
ENS_REVERSE_REGISTRAR_ADDRESS=0x4F382928805ba0e23B30cFB75fC9E848e82DFD47

# Rental/access demo defaults
RENTAL_DURATION_DAYS=30
BRAIN_ENS_NAME=solidity-auditor.0mcp.eth
RENTER_ADDRESS=0x_your_renter_wallet_here
RENTAL_SUBNAME=

# ── KeeperHub ─────────────────────────────────────────────────────────────────
# MCP endpoint: https://app.keeperhub.com/mcp
# Generate your API key at: https://app.keeperhub.com → Settings → API Keys → Organisation
KEEPER_API_KEY=kh_your_api_key_here

# ── Uniswap (Sepolia Testnet) ─────────────────────────────────────────────────
# Uniswap v3 is deployed on Sepolia — no extra key needed
# Factory: 0x0227628f3F023bb0B980b67D528571c95c6DaC1c
# Router: 0x3bFA4769FB09eefC5a80d6E87c3B9C650f7Ae48

# ── Developer Options ─────────────────────────────────────────────────────────
# Set to true to use in-memory mock storage instead of 0G (demo day fallback)
MOCK_STORAGE=false

# Optional ENS label/description used by npm run register-agent
AGENT_ENS_LABEL=solidity-auditor
AGENT_DESCRIPTION=0MCP Brain agent registered from the local demo

# Set to true to print keyword scores during context retrieval (demo/debug)
DEBUG_CONTEXT=false
