# 0MCP Environment Configuration Example
# Copy this file to .env.0mcp and fill in your values.

# ── USER CREDENTIALS ──────────────────────────────
# Export an EVM private key for standard operations
ZG_PRIVATE_KEY="0xYourPrivateKeyHex..."

# ── CONNECTIONS (Optional) ────────────────────────
# KeeperHub API Key for routed ENS / Payment swaps (app.keeperhub.com)
# KEEPER_API_KEY="kh_..."
