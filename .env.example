# =============================================================================
# 0MCP — Environment Variables
# Copy this to .env and fill in your values.
# NEVER commit .env to git.
# =============================================================================

# ── 0G Network (Newton Testnet) ───────────────────────────────────────────────
# RPC endpoint for 0G Newton testnet EVM
# Docs: https://docs.0g.ai/build-with-0g/networks
ZG_RPC_URL=https://evmrpc-testnet.0g.ai

# Public KV node for read/write — primary node
ZG_KV_NODE=http://3.101.147.150:6789

# Fallback KV node (used if primary is unreachable)
ZG_KV_FALLBACK_NODE=http://3.101.147.150:6790

# 0G storage indexer — used to select upload nodes
# Docs: https://docs.0g.ai/build-with-0g/storage-sdk
ZG_INDEXER_RPC=https://indexer-storage-testnet-standard.0g.ai

# Your testnet wallet private key (0x-prefixed)
# Get testnet OG tokens free at: https://faucet.0g.ai
ZG_PRIVATE_KEY=0x_your_private_key_here

# ── Brain iNFT Contract ────────────────────────────────────────────────────────
# Address of SimpleINFT.sol deployed on 0G testnet (chain ID 16600)
# Deploy with Foundry: forge create --rpc-url $ZG_RPC_URL ...
# Leave blank until Phase 4 deployment
INFT_CONTRACT_ADDRESS=

# Your wallet address (for minting iNFTs to yourself)
MY_WALLET_ADDRESS=0x_your_wallet_address_here

# ── ENS (Sepolia Testnet) ─────────────────────────────────────────────────────
# Private key for the wallet that owns 0mcp.eth on Sepolia
# Can be same as ZG_PRIVATE_KEY if same wallet
# Sepolia ENS: https://app.ens.domains (switch to Sepolia in wallet)
# Get Sepolia ETH: https://sepoliafaucet.com
ENS_PRIVATE_KEY=0x_your_private_key_here

# Sepolia RPC (for ENS interactions)
# Free Sepolia RPC: https://rpc.sepolia.org  OR  https://1rpc.io/sepolia
SEPOLIA_RPC_URL=https://rpc.sepolia.org

# ── KeeperHub ─────────────────────────────────────────────────────────────────
# MCP endpoint: https://app.keeperhub.com/mcp
# Generate your API key at: https://app.keeperhub.com → Settings → API Keys → Organisation
KEEPER_API_KEY=kh_your_api_key_here

# ── Uniswap (Sepolia Testnet) ─────────────────────────────────────────────────
# Uniswap v3 is deployed on Sepolia — no extra key needed
# Factory: 0x0227628f3F023bb0B980b67D528571c95c6DaC1c
# Router: 0x3bFA4769FB09eefC5a80d6E87c3B9C650f7Ae48

# ── Developer Options ─────────────────────────────────────────────────────────
# Set to true to use in-memory mock storage instead of 0G (demo day fallback)
MOCK_STORAGE=false

# Set to true to print keyword scores during context retrieval (demo/debug)
DEBUG_CONTEXT=false
